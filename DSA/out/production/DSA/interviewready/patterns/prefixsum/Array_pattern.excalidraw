    {
      "id": "TxNtSxsxgeQbKh8oILQoc",
      "type": "text",
      "x": 1462.0358567010796,
      "y": 3294.2303910028363,
      "width": 546.51953125,
      "height": 625,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0d",
      "roundness": null,
      "seed": 1557923517,
      "version": 47,
      "versionNonce": 2096129175,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1783519612183,
      "link": null,
      "locked": false,
      "text": "Matrix sorted row wise\npublic boolean searchMatrix(int[][] matrix, int target) {\n    int rows = matrix.length;\n    int cols = matrix[0].length;\n\n    int start = 0;\n    int end = rows * cols - 1;\n\n    while (start <= end) {\n        int mid = start + (end - start) / 2;\n\n        int row = mid / cols;\n        int col = mid % cols;\n\n        if (matrix[row][col] == target)\n            return true;\n\n        if (matrix[row][col] < target)\n            start = mid + 1;\n        else\n            end = mid - 1;\n    }\n\n    return false;\n}",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Matrix sorted row wise\npublic boolean searchMatrix(int[][] matrix, int target) {\n    int rows = matrix.length;\n    int cols = matrix[0].length;\n\n    int start = 0;\n    int end = rows * cols - 1;\n\n    while (start <= end) {\n        int mid = start + (end - start) / 2;\n\n        int row = mid / cols;\n        int col = mid % cols;\n\n        if (matrix[row][col] == target)\n            return true;\n\n        if (matrix[row][col] < target)\n            start = mid + 1;\n        else\n            end = mid - 1;\n    }\n\n    return false;\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },

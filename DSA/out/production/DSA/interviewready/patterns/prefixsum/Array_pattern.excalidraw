    {
      "id": "nWc4yqzaZkf_m5Wbpggln",
      "type": "text",
      "x": 1672.0358567010796,
      "y": 4064.0518195742648,
      "width": 546.51953125,
      "height": 500,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,

    {
      "id": "M0vSMTmFPwOG5w7r_cjNV",
      "type": "text",
      "x": -120.82137334914353,
      "y": 4402.14704313732,
      "width": 473.5997009277344,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1P",
      "roundness": null,
      "seed": 836403161,
      "version": 336,
      "versionNonce": 1970982137,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783521268675,
      "link": null,
      "locked": false,
      "text": "Estimation\nchar = 1 byte\nAssume Url string length = 100 char = 100 bytes\nTiny Url string length = 40 char = 40 bytes\nUser info = 10 byte per record\nDb capacity for 100 users = 100*10 = 1GB\nDb capacity for 10M urls= 10M*(100 *40) \n= 4000M = 4TB\n\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Estimation\nchar = 1 byte\nAssume Url string length = 100 char = 100 bytes\nTiny Url string length = 40 char = 40 bytes\nUser info = 10 byte per record\nDb capacity for 100 users = 100*10 = 1GB\nDb capacity for 10M urls= 10M*(100 *40) \n= 4000M = 4TB\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },

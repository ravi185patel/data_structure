      "groupIds": [],
      "frameId": null,
      "index": "b0i",
      "roundness": null,
      "seed": 1004927091,
      "version": 14,
      "versionNonce": 785719609,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1783519612183,
      "link": null,
      "locked": false,
      "text": "public boolean searchMatrix(int[][] matrix, int target) {\n    int rows = matrix.length;\n    int cols = matrix[0].length;\n\n    int r = 0;\n    int c = cols - 1;\n\n    while (r < rows && c >= 0) {\n\n        if (matrix[r][c] == target)\n            return true;\n\n        if (matrix[r][c] > target)\n            c--;\n        else\n            r++;\n    }\n\n    return false;\n}",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "public boolean searchMatrix(int[][] matrix, int target) {\n    int rows = matrix.length;\n    int cols = matrix[0].length;\n\n    int r = 0;\n    int c = cols - 1;\n\n    while (r < rows && c >= 0) {\n\n        if (matrix[r][c] == target)\n            return true;\n\n        if (matrix[r][c] > target)\n            c--;\n        else\n            r++;\n    }\n\n    return false;\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },

    {
      "id": "1OKTIAghRzMxDpG__NJ32",
      "type": "text",
      "x": 942.1667175292969,
      "y": 1040.1666412353516,
      "width": 498.9081756591801,
      "height": 381.42857142857156,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",

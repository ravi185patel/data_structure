      "updated": 1783521103814,
      "link": null,
      "locked": false,
      "text": "Flow:\n1) User Enter Url -> tinyUrl application -> check URL exists (yes) -> redirect to original url\n2) User Enter Url -> tinyUrl application -> check URL exists (no) -> add entry in db -> redirect to original url",
      "fontSize": 19.92380952380967,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Flow:\n1) User Enter Url -> tinyUrl application -> check URL exists (yes) -> redirect to original url\n2) User Enter Url -> tinyUrl application -> check URL exists (no) -> add entry in db -> redirect to original url",
      "autoResize": false,
      "lineHeight": 1.25
    },

      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "MKeX5plhbyg8bHMH5VE0j",
      "type": "text",
      "x": 867.4999999999998,
      "y": 1479.5238058907646,
      "width": 783.8611843522617,
      "height": 685.9999999999989,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aa",
      "roundness": null,
      "seed": 1738056193,
      "version": 351,
      "versionNonce": 542838681,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783519612183,
      "link": null,
      "locked": false,
      "text": "3. Prefix Sum + HashMap (Subarray Sum = K)\npublic int subarraySum(int[] nums, int k) {\n    Map<Long, Integer> map = new HashMap<>();\n\n    map.put(0L, 1);\n\n    long prefix = 0;\n    int count = 0;\n\n    for (int num : nums) {\n        prefix += num;\n\n        count += map.getOrDefault(prefix - k, 0);\n\n        map.put(prefix,\n                map.getOrDefault(prefix, 0) + 1);\n    }\n\n    return count;\n}",
      "fontSize": 27.439999999999948,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "3. Prefix Sum + HashMap (Subarray Sum = K)\npublic int subarraySum(int[] nums, int k) {\n    Map<Long, Integer> map = new HashMap<>();\n\n    map.put(0L, 1);\n\n    long prefix = 0;\n    int count = 0;\n\n    for (int num : nums) {\n        prefix += num;\n\n        count += map.getOrDefault(prefix - k, 0);\n\n        map.put(prefix,\n                map.getOrDefault(prefix, 0) + 1);\n    }\n\n    return count;\n}",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "DxhEf5FJwuprmKSPW1e_w",
      "type": "text",
      "x": 1680.5792875744055,
      "y": 1661.3219672414334,
      "width": 956.2646517804933,
      "height": 894.2025800286667,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ab",
      "roundness": null,
      "seed": 2007489583,
      "version": 610,
      "versionNonce": 1917981303,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783519612183,
      "link": null,
      "locked": false,
      "text": "4. Longest Subarray with Sum K\npublic int longestSubarray(int[] nums, int k) {\n    Map<Long, Integer> map = new HashMap<>();\n\n    long prefix = 0;\n    int maxLen = 0;\n\n    for (int i = 0; i < nums.length; i++) {\n        prefix += nums[i];\n\n        if (prefix == k) {\n            maxLen = i + 1;\n        }\n\n        if (map.containsKey(prefix - k)) {\n            maxLen = Math.max(maxLen,\n                              i - map.get(prefix - k));\n        }\n\n        map.putIfAbsent(prefix, i);\n    }\n\n    return maxLen;\n}",
      "fontSize": 29.806752667622227,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "4. Longest Subarray with Sum K\npublic int longestSubarray(int[] nums, int k) {\n    Map<Long, Integer> map = new HashMap<>();\n\n    long prefix = 0;\n    int maxLen = 0;\n\n    for (int i = 0; i < nums.length; i++) {\n        prefix += nums[i];\n\n        if (prefix == k) {\n            maxLen = i + 1;\n        }\n\n        if (map.containsKey(prefix - k)) {\n            maxLen = Math.max(maxLen,\n                              i - map.get(prefix - k));\n        }\n\n        map.putIfAbsent(prefix, i);\n    }\n\n    return maxLen;\n}",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "lB_aPBjr3hPyyvFJBesJ_",
      "type": "text",
      "x": 1681.4364304315475,
      "y": 999.9047829764229,
      "width": 708.9585008315938,
      "height": 611.0000000000001,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ac",
      "roundness": null,
      "seed": 1436359297,
      "version": 246,
      "versionNonce": 560444537,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783519612183,
      "link": null,
      "locked": false,
      "text": "5. Equal 0s and 1s\nMap<Integer, Integer> map = new HashMap<>();\n\nmap.put(0, -1);\n\nint prefix = 0;\nint maxLen = 0;\n\nfor (int i = 0; i < nums.length; i++) {\n\n    prefix += (nums[i] == 0 ? -1 : 1);\n\n    if (map.containsKey(prefix)) {\n        maxLen = Math.max(maxLen,\n                          i - map.get(prefix));\n    } else {\n        map.put(prefix, i);\n    }\n}",
      "fontSize": 25.72631578947369,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "5. Equal 0s and 1s\nMap<Integer, Integer> map = new HashMap<>();\n\nmap.put(0, -1);\n\nint prefix = 0;\nint maxLen = 0;\n\nfor (int i = 0; i < nums.length; i++) {\n\n    prefix += (nums[i] == 0 ? -1 : 1);\n\n    if (map.containsKey(prefix)) {\n        maxLen = Math.max(maxLen,\n                          i - map.get(prefix));\n    } else {\n        map.put(prefix, i);\n    }\n}",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "hBraAtJcQ3ExiEwP3-gI8",

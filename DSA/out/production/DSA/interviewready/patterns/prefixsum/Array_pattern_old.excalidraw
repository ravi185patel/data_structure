    {
      "id": "Y3iW-gN0xl4d55xcmPUKM",
      "type": "text",
      "x": -301.13499813988085,
      "y": 1786.761925833566,
      "width": 810.2556762695312,
      "height": 971.1764705882352,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ar",
      "roundness": null,
      "seed": 308958273,
      "version": 390,
      "versionNonce": 659340633,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783519612183,
      "link": null,
      "locked": false,
      "text": "// Build prefix\npref[i + 1] = pref[i] + arr[i];\n\n// Range sum\npref[r + 1] - pref[l];\n\n// Count subarrays sum = k\ncount += map.getOrDefault(prefix - k, 0);\n\n// Longest subarray sum = k\nif (map.containsKey(prefix - k))\n\n// Balanced 0s and 1s\n0 -> -1, 1 -> +1\n\npref[r + 1] - pref[l] (range queries)\nHashMap<prefixSum, frequency> (subarray sum problems)\n\n// Two Diamensional\npref[r][c] = pref[r-1][c-1] + pref[r-1][c] \n                + prev[r][c-1] - prev[r-1][c-1];\n\n// Range query (r1,c1,r2,c2)\nans[i] = pref[r2+1][c2+1] - pref[r1][c2+1] \n                - prev[r2+1][c1] + prev[r1][c1];\n",
      "fontSize": 29.88235294117647,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "// Build prefix\npref[i + 1] = pref[i] + arr[i];\n\n// Range sum\npref[r + 1] - pref[l];\n\n// Count subarrays sum = k\ncount += map.getOrDefault(prefix - k, 0);\n\n// Longest subarray sum = k\nif (map.containsKey(prefix - k))\n\n// Balanced 0s and 1s\n0 -> -1, 1 -> +1\n\npref[r + 1] - pref[l] (range queries)\nHashMap<prefixSum, frequency> (subarray sum problems)\n\n// Two Diamensional\npref[r][c] = pref[r-1][c-1] + pref[r-1][c] \n                + prev[r][c-1] - prev[r-1][c-1];\n\n// Range query (r1,c1,r2,c2)\nans[i] = pref[r2+1][c2+1] - pref[r1][c2+1] \n                - prev[r2+1][c1] + prev[r1][c1];\n",
      "autoResize": true,
      "lineHeight": 1.25
    },

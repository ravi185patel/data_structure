      "seed": 308958273,
      "version": 183,
      "versionNonce": 1694835919,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1782374116233,
      "link": null,
      "locked": false,
      "text": "// Build prefix\npref[i + 1] = pref[i] + arr[i];\n\n// Range sum\npref[r + 1] - pref[l];\n\n// Count subarrays sum = k\ncount += map.getOrDefault(prefix - k, 0);\n\n// Longest subarray sum = k\nif (map.containsKey(prefix - k))\n\n// Balanced 0s and 1s\n0 -> -1, 1 -> +1\n\npref[r + 1] - pref[l] (range queries)\nHashMap<prefixSum, frequency> (subarray sum problems)",
      "fontSize": 29.88235294117647,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "// Build prefix\npref[i + 1] = pref[i] + arr[i];\n\n// Range sum\npref[r + 1] - pref[l];\n\n// Count subarrays sum = k\ncount += map.getOrDefault(prefix - k, 0);\n\n// Longest subarray sum = k\nif (map.containsKey(prefix - k))\n\n// Balanced 0s and 1s\n0 -> -1, 1 -> +1\n\npref[r + 1] - pref[l] (range queries)\nHashMap<prefixSum, frequency> (subarray sum problems)",
      "autoResize": true,
      "lineHeight": 1.25
    },
